generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/guildops_landing/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model BetaSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  guildName String
  realm     String
  role      String
  createdAt DateTime @default(now())
}
